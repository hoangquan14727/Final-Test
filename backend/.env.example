# MongoDB Atlas SRV connection string. Keep the /school path so Mongoose uses the "school" DB.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/school?retryWrites=true&w=majority

# Port the API listens on
PORT=5000

# Allowed CORS origin (Vite dev server)
CORS_ORIGIN=http://localhost:5173
